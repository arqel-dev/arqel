{
  "name": "arqel/demo-app",
  "description": "Demo end-to-end do framework Arqel — blog admin com AI, workflow, versioning e audit.",
  "type": "project",
  "license": "MIT",
  "version": "0.8.0-rc.1",
  "keywords": ["laravel", "arqel", "demo", "showcase", "inertia", "react"],
  "homepage": "https://demo.arqel.dev",
  "require": {
    "php": "^8.3",
    "arqel/core": "@dev",
    "laravel/framework": "^12.0|^13.0",
    "inertiajs/inertia-laravel": "^1.0|^2.0|^3.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.9",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "repositories": [
    { "type": "path", "url": "../../packages/core", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/fields", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/auth", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/table", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/form", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/actions", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/nav", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/ai", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/workflow", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/versioning", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/audit", "options": { "symlink": true } }
  ],
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "test": "vendor/bin/pest",
    "lint": "pint --test",
    "format": "pint"
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
