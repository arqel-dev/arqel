{
  "name": "@arqel-dev/ui",
  "version": "0.11.0",
  "description": "Structural React components (AppShell, DataTable, FormRenderer, etc.) for Arqel admin panels.",
  "license": "MIT",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel-dev/arqel.git",
    "directory": "packages-js/ui"
  },
  "keywords": [
    "arqel",
    "laravel",
    "inertia",
    "react",
    "ui",
    "shadcn",
    "tailwind"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    },
    "./resource": {
      "types": "./dist/resource.d.ts",
      "import": "./dist/resource.js"
    },
    "./table": {
      "types": "./dist/table.d.ts",
      "import": "./dist/table.js"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js"
    },
    "./action": {
      "types": "./dist/action.d.ts",
      "import": "./dist/action.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./flash": {
      "types": "./dist/flash.d.ts",
      "import": "./dist/flash.js"
    },
    "./utility": {
      "types": "./dist/utility.d.ts",
      "import": "./dist/utility.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "import": "./dist/pages.js"
    },
    "./palette": {
      "types": "./dist/palette.d.ts",
      "import": "./dist/palette.js"
    },
    "./widgets": {
      "types": "./dist/widgets.d.ts",
      "import": "./dist/widgets.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./styles.css": "./src/styles/globals.css"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --diagnostic-level=error src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arqel-dev/types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "@arqel-dev/hooks": "workspace:*",
    "@arqel-dev/react": "workspace:*",
    "@inertiajs/react": "^2.0.0",
    "@tanstack/react-table": "^8.20.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@arqel-dev/hooks": "workspace:*",
    "@arqel-dev/react": "workspace:*",
    "@base-ui-components/react": "^1.0.0-alpha.0",
    "@inertiajs/react": "^2.0.0",
    "@tanstack/react-table": "^8.20.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
