{
    "name": "arqel-dev/marketplace",
    "version": "0.9.3",
    "description": "Plugin marketplace backend for Arqel — schema, models e REST API para descoberta/publicação de plugins community.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "arqel",
        "marketplace",
        "plugins"
    ],
    "homepage": "https://arqel.dev",
    "support": {
        "issues": "https://github.com/arqel-dev/arqel/issues",
        "source": "https://github.com/arqel-dev/arqel",
        "docs": "https://arqel.dev/docs"
    },
    "require": {
        "php": "^8.3",
        "arqel-dev/core": "@dev",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "stripe/stripe-php": "^15.0|^16.0"
    },
    "suggest": {
        "stripe/stripe-php": "Required to enable StripeConnectGateway for premium plugins (composer require stripe/stripe-php)."
    },
    "autoload": {
        "psr-4": {
            "Arqel\\Marketplace\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arqel\\Marketplace\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arqel\\Marketplace\\MarketplaceServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=90",
        "analyse": "phpstan analyse src tests",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
