{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "arqel-dev/marketplace-app",
  "description": "Frontend público do marketplace Arqel — Laravel + Inertia + React, dogfood do framework Arqel.",
  "type": "project",
  "license": "MIT",
  "keywords": ["laravel", "arqel", "marketplace", "inertia", "react"],
  "homepage": "https://marketplace.arqel.dev",
  "require": {
    "php": "^8.3",
    "arqel-dev/core": "@dev",
    "arqel-dev/marketplace": "@dev",
    "inertiajs/inertia-laravel": "^1.0|^2.0|^3.0",
    "laravel/framework": "^12.0|^13.0",
    "laravel/tinker": "^2.9"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "larastan/larastan": "^3.9",
    "laravel/pint": "^1.29",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.0",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "repositories": [
    { "type": "path", "url": "../../packages/core", "options": { "symlink": true } },
    { "type": "path", "url": "../../packages/marketplace", "options": { "symlink": true } }
  ],
  "scripts": {
    "test": "vendor/bin/pest",
    "lint": "pint --test",
    "format": "pint",
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
