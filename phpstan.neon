# Base PHPStan config para o monorepo.
#
# Notas:
# - Larastan só é carregado em packages que dependam de laravel/framework.
#   Cada package PHP extende este ficheiro via `includes:` no seu phpstan.neon
#   local e adiciona `vendor/larastan/larastan/extension.neon` (via Composer
#   symlink para a vendor raiz).
# - Este ficheiro NÃO inclui Larastan directamente porque a raiz do monorepo
#   não depende de Laravel (evita Fatal Error por falta da constante
#   LARAVEL_VERSION).

parameters:
    level: max
    paths:
        - packages
    excludePaths:
        analyseAndScan:
            - packages/*/tests/*
            - packages/*/vendor/*
            - packages/*/database/*
            - packages/*/node_modules/*
        analyse:
            - packages/*/config/*
    tmpDir: .phpstan.cache
    parallel:
        maximumNumberOfProcesses: 4
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Traits are analysed in isolation; PHPStan flags them as
        # `trait.unused` when no class in the analysis paths actually
        # uses them. Our traits are consumed by user-land Eloquent
        # models, so the warning is a false positive here.
        -
            identifier: trait.unused
            path: packages/tenant/src/Concerns/*.php
