{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(composer:*)",
      "Bash(php:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(vendor/bin/*)",
      "Bash(./scripts/*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(chmod 777:*)"
    ]
  },
  "defaultMode": "autonomous",
  "autonomousMode": {
    "stopOn": [
      "external-api-costs",
      "new-dependencies",
      "security-changes",
      "adr-conflicts",
      "breaking-changes",
      "ambiguous-requirements"
    ]
  },
  "hooks": {
    "beforeCommit": "./scripts/pre-commit-check.sh",
    "afterFileEdit": null
  },
  "context": {
    "alwaysInclude": [
      "CLAUDE.md",
      "docs/tickets/current.md"
    ],
    "planningDocs": "PLANNING/"
  }
}
