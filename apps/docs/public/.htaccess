# VitePress site — Apache rewrite rules for clean URLs.
#
# VitePress builds with cleanUrls: true, producing /guide/getting-started.html
# on disk. Apache must serve that file when the user requests
# /guide/getting-started (no extension). This .htaccess is copied verbatim
# from public/ to the dist root by VitePress, so it ends up next to the
# generated HTML on the server.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the request maps to an existing file or directory, serve as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Strip trailing slash on extensionless paths
  # (so /guide/foo/ behaves the same as /guide/foo).
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # If <path>.html exists, serve it for /<path>.
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Fallback: VitePress 404 page.
  ErrorDocument 404 /404.html
</IfModule>

# Sensible cache headers — assets are content-hashed by VitePress.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip / Brotli compression (most Hostinger setups have these).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
