{
  "name": "@arqel-dev/fields",
  "version": "0.9.3",
  "description": "Rich React input components for Arqel — registered into @arqel-dev/ui's FieldRegistry.",
  "license": "MIT",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel-dev/arqel.git",
    "directory": "packages-js/fields-js"
  },
  "keywords": [
    "arqel",
    "laravel",
    "inertia",
    "react",
    "fields",
    "shadcn"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "import": "./dist/text.js"
    },
    "./number": {
      "types": "./dist/number.d.ts",
      "import": "./dist/number.js"
    },
    "./boolean": {
      "types": "./dist/boolean.d.ts",
      "import": "./dist/boolean.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js"
    },
    "./relationship": {
      "types": "./dist/relationship.d.ts",
      "import": "./dist/relationship.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.js"
    },
    "./file": {
      "types": "./dist/file.d.ts",
      "import": "./dist/file.js"
    },
    "./slug": {
      "types": "./dist/slug.d.ts",
      "import": "./dist/slug.js"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "import": "./dist/color.js"
    },
    "./hidden": {
      "types": "./dist/hidden.d.ts",
      "import": "./dist/hidden.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --diagnostic-level=error src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arqel-dev/types": "workspace:*"
  },
  "peerDependencies": {
    "@arqel-dev/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@arqel-dev/ui": "workspace:*",
    "@inertiajs/react": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
