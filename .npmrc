# Permite instalar automaticamente peer deps (crítico para React 19 + libs legacy)
auto-install-peers=true

# Flexibiliza peer ranges — evita bloqueios por peer ranges conservadores de libs upstream
strict-peer-dependencies=false

# Deixa o pnpm resolver workspace:* durante o build local
link-workspace-packages=true

# Usa symlinks (não hardlinks) para workspaces — melhor DX quando o editor segue links
prefer-workspace-packages=true

# Assinalar warnings ao tentar publicar sem autenticação (evitar leaks acidentais)
# Comentado por default — activar em CI de release
# registry=https://registry.npmjs.org/

# Desactivar a mensagem de "update available" em CI
update-notifier=false
