{
  "name": "arqel-dev/marketplace-app",
  "description": "Frontend público do marketplace Arqel — Laravel + Inertia + React, dogfood do framework Arqel.",
  "type": "project",
  "license": "MIT",
  "keywords": ["laravel", "arqel", "marketplace", "inertia", "react"],
  "homepage": "https://marketplace.arqel.dev",
  "require": {
    "php": "^8.3",
    "arqel-dev/core": "@dev",
    "arqel-dev/marketplace": "@dev",
    "illuminate/http": "^12.0|^13.0",
    "illuminate/routing": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/view": "^12.0|^13.0",
    "inertiajs/inertia-laravel": "^1.0|^2.0|^3.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.9",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../packages/core",
      "options": { "symlink": true }
    },
    {
      "type": "path",
      "url": "../../packages/marketplace",
      "options": { "symlink": true }
    }
  ],
  "scripts": {
    "test": "vendor/bin/pest",
    "lint": "pint --test",
    "format": "pint"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
