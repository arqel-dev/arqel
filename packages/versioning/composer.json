{
    "name": "arqel-dev/versioning",
    "version": "0.9.1",
    "description": "Time-travel record versioning for Arqel — Versionable trait + version snapshots with diff tracking and pruning.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "arqel",
        "versioning",
        "time-travel",
        "audit"
    ],
    "homepage": "https://arqel.dev",
    "support": {
        "issues": "https://github.com/arqel-dev/arqel/issues",
        "source": "https://github.com/arqel-dev/arqel",
        "docs": "https://arqel.dev/docs"
    },
    "require": {
        "php": "^8.3",
        "arqel-dev/core": "@dev",
        "illuminate/support": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "suggest": {
        "spatie/laravel-eventsourcing": "Optional — pair with arqel-dev/versioning when migrating to a full event-sourced model (^7.0)."
    },
    "autoload": {
        "psr-4": {
            "Arqel\\Versioning\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arqel\\Versioning\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arqel\\Versioning\\VersioningServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=90",
        "analyse": "phpstan analyse src tests",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
