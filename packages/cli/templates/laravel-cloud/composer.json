{
    "name": "your-org/{{APP_NAME}}",
    "type": "project",
    "description": "Arqel admin panel deployed to Laravel Cloud.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "arqel/core": "^0.1",
        "arqel/panel": "^0.1",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.0",
        "inertiajs/inertia-laravel": "^2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
