# Força LF em todos os arquivos de texto — consistência cross-platform
* text=auto eol=lf

# Código fonte
*.php     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.mdx     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.xml     text eol=lf
*.neon    text eol=lf
*.env     text eol=lf

# Shell scripts — LF obrigatório
*.sh      text eol=lf
*.bash    text eol=lf

# Scripts Windows — CRLF (se existirem)
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binários — nunca transformar
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.avif    binary
*.ico     binary
*.svg     text eol=lf
*.pdf     binary
*.zip     binary
*.tar.gz  binary
*.tgz     binary
*.phar    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary

# Exportação — excluir do tarball de release
.github/          export-ignore
.gitattributes    export-ignore
.gitignore        export-ignore
.editorconfig     export-ignore
PLANNING/         export-ignore
docs/             export-ignore
tests/            export-ignore
*.test.ts         export-ignore
*.spec.ts         export-ignore

# Linguist (GitHub) — docs do planejamento não contam como código
PLANNING/* linguist-documentation
docs/*     linguist-documentation
