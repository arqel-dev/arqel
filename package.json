{
  "name": "arqel",
  "version": "0.0.0",
  "description": "Admin panels for Laravel, forged in PHP, rendered in React.",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel-dev/arqel.git"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm -r --parallel --if-present run dev",
    "test": "pnpm -r --if-present run test",
    "test:all": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint:php": "vendor/bin/pint --test",
    "format:php": "vendor/bin/pint",
    "analyse:php": "vendor/bin/phpstan analyse",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules .pnpm-store .phpstan.cache",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched",
    "*.php": "vendor/bin/pint --dirty"
  },
  "keywords": [
    "laravel",
    "admin",
    "panel",
    "react",
    "inertia",
    "shadcn",
    "typescript"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "ip-address@<10.1.1": ">=10.1.1"
    }
  }
}
