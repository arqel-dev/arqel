{
    "name": "arqel-dev/cli",
    "version": "0.9.4",
    "description": "Standalone CLI for Arqel — interactive scaffolder (`arqel new`) and meta tooling.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "arqel",
        "cli",
        "scaffolder"
    ],
    "homepage": "https://arqel.dev",
    "support": {
        "issues": "https://github.com/arqel-dev/arqel/issues",
        "source": "https://github.com/arqel-dev/arqel",
        "docs": "https://arqel.dev/docs"
    },
    "require": {
        "php": "^8.3",
        "laravel/prompts": "^0.3",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Arqel\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arqel\\Cli\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/arqel"
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "phpstan analyse",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
