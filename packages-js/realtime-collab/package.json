{
  "name": "@arqel-dev/realtime-collab",
  "version": "0.11.0",
  "description": "Yjs collaborative editing client for Arqel — sync via Laravel Echo + Reverb.",
  "license": "MIT",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel-dev/arqel.git",
    "directory": "packages-js/realtime-collab"
  },
  "keywords": [
    "arqel",
    "laravel",
    "yjs",
    "crdt",
    "collaborative",
    "realtime",
    "reverb",
    "echo"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yjs": "^13.6.0",
    "y-protocols": "^1.0.0"
  },
  "peerDependencies": {
    "@inertiajs/react": "^3.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@inertiajs/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.9.0"
  }
