includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: max
    paths:
        - src
        - tests
    excludePaths:
        analyseAndScan:
            - vendor/*
    tmpDir: .phpstan.cache
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # The Versionable trait is consumed by user-land Eloquent models;
        # PHPStan cannot see a concrete consumer in the analysed paths and
        # would report `trait.unused`. Tests use it via fixtures under
        # `tests/Fixtures/`.
        -
            identifier: trait.unused
            path: src/Concerns/Versionable.php
        # `Version::user()` is intentionally `?BelongsTo` (returns null when
        # the configured user_model is missing). Larastan rejects nullable
        # relation methods for `with('user')`; the controller eager-loads it
        # only after a runtime null-check.
        -
            identifier: larastan.relationExistence
            path: src/Http/Controllers/VersionHistoryController.php
