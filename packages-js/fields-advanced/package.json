{
  "name": "@arqel-dev/fields-advanced",
  "version": "0.10.1",
  "description": "Advanced React input components for Arqel — RichText, Markdown, Code, Repeater, Builder, KeyValue, Tags, Wizard.",
  "license": "MIT",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel-dev/arqel.git",
    "directory": "packages-js/fields-advanced"
  },
  "keywords": [
    "arqel",
    "laravel",
    "inertia",
    "react",
    "fields",
    "advanced",
    "rich-text",
    "markdown",
    "code",
    "repeater",
    "builder",
    "wizard"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./rich-text": {
      "types": "./dist/rich-text.d.ts",
      "import": "./dist/rich-text.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./code": {
      "types": "./dist/code.d.ts",
      "import": "./dist/code.js"
    },
    "./repeater": {
      "types": "./dist/repeater.d.ts",
      "import": "./dist/repeater.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js"
    },
    "./key-value": {
      "types": "./dist/key-value.d.ts",
      "import": "./dist/key-value.js"
    },
    "./tags": {
      "types": "./dist/tags.d.ts",
      "import": "./dist/tags.js"
    },
    "./wizard": {
      "types": "./dist/wizard.d.ts",
      "import": "./dist/wizard.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --diagnostic-level=error src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arqel-dev/types": "workspace:*",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@tiptap/extension-character-count": "^2.10.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0",
    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "shiki": "^3.0.0"
  },
  "peerDependencies": {
    "@arqel-dev/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@arqel-dev/ui": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
