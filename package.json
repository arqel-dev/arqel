{
  "name": "arqel",
  "version": "0.0.0",
  "description": "Admin panels for Laravel, forged in PHP, rendered in React.",
  "homepage": "https://arqel.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/arqel/arqel.git"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm -r --parallel --if-present run dev",
    "test": "pnpm -r --if-present run test",
    "test:all": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules .pnpm-store"
  },
  "keywords": [
    "laravel",
    "admin",
    "panel",
    "react",
    "inertia",
    "shadcn",
    "typescript"
  ]
}
